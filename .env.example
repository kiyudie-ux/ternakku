# Backend Configuration
NODE_ENV=production
PORT=5000
DATABASE_URL=postgresql://user:password@localhost:5432/digjaya
REDIS_URL=redis://localhost:6379

# Midtrans Configuration (CRITICAL)
MIDTRANS_SERVER_KEY=YOUR_SERVER_KEY_HERE
MIDTRANS_CLIENT_KEY=YOUR_CLIENT_KEY_HERE
MIDTRANS_ENVIRONMENT=production

# JWT & Security
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRY=7d
WEBHOOK_SIGNATURE_KEY=your-webhook-signature-key

# API Configuration
API_URL=https://api.digjaya.id
FRONTEND_URL=https://digjaya.id

# AI Engine
OPENAI_API_KEY=sk-your-key-here
AI_MODEL=gpt-4

# Email Service
SENDGRID_API_KEY=your-sendgrid-key
SENDER_EMAIL=noreply@digjaya.id

# AWS S3 (Image Storage)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=digjaya-livestock-images

# Payout Configuration
BANK_API_KEY=your-bank-api-key